# TrustRate — configuration de PRODUCTION.
# Copiez ce fichier en ".env" à côté de docker-compose.prod.yml et remplissez tout.
# Le fichier .env ne doit JAMAIS être publié ni commité.

# ── Votre nom de domaine (déjà pointé vers l'IP du serveur, sans https://) ──
DOMAIN=trustrate.exemple.fr

# ── Mots de passe : longs et aléatoires. Pour en générer un :
#    Linux/Mac : openssl rand -base64 24
#    Windows   : [Convert]::ToBase64String((1..24|%{Get-Random -Max 256}))
POSTGRES_PASSWORD=CHANGEZ_MOI
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGEZ_MOI

# ── Identité affichée sur les mentions légales et la page confidentialité ──
EDITOR_NAME=Prénom Nom (ou raison sociale)
EDITOR_STATUS=Entrepreneur individuel — SIREN 000 000 000 — Ville
CONTACT_EMAIL=contact@trustrate.exemple.fr
HOST_NAME=Hetzner Online GmbH, Industriestr. 25, 91710 Gunzenhausen, Allemagne

# ── Réglages métier (valeurs par défaut très bien pour démarrer) ──
MIN_COHORT=8
